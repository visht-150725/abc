# =========================================
# CHEAT 6 (Forest Fire Visualization)
# =========================================

forest = pd.read_csv("forestfires.csv")

# Line graph
forest.groupby('month')['area'].sum().plot(kind='line')
plt.title("Monthly Burned Area")
plt.show()

# Bar chart
forest['month'].value_counts().plot(kind='bar')
plt.title("Fire Frequency")
plt.show()

# Histogram
plt.hist(forest['area'])
plt.title("Area Distribution")
plt.show()

# Scatter
plt.scatter(forest['wind'], forest['area'])
plt.title("Wind vs Area")
plt.show()

# Box plot
sns.boxplot(x=forest['temp'])
plt.title("Temperature Impact")
plt.show()

# Heatmap
corr = forest[['temp','RH','wind','rain']].corr()
sns.heatmap(corr, annot=True)
plt.title("Correlation")
plt.show()


