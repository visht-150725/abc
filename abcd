# =========================================
# CHEAT 4 (Air Quality - Processing + Model)
# =========================================

air = pd.read_csv("air_quality.csv")

# Cleaning
air = air.drop_duplicates()
air = air.dropna()

# Transformation (encoding)
if 'City' in air.columns:
    air['City'] = air['City'].astype('category').cat.codes

# Error correction
if 'AQI' in air.columns:
    air = air[air['AQI'] > 0]

# Model
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression

if set(['PM2.5','PM10','NO2','AQI']).issubset(air.columns):
    X = air[['PM2.5','PM10','NO2']]
    y = air['AQI']

    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)
    model = LinearRegression()
    model.fit(X_train, y_train)
    pred = model.predict(X_test)


